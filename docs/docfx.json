{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
  {
    "src": [
      {
        "src": "..",
        "files": [ "**/*.cs" ],
        "exclude": [ "**/bin/**", "**/obj/**", "docs/**" ]
      }
    ],
    "dest": "api",
    "allowCompilationErrors": true,
    "properties": {
      "TargetFramework": "netstandard2.0"
    }
  }
],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "",
      "_appTitle": "",
      "_enableSearch": true,
      "pdf": true
    }
  }
}